# === Required ===
SERPAPI_KEY=your_serpapi_key_here
GROQ_API_KEY=gsk_your_groq_api_key_here

# === Optional — Google ===
PAGESPEED_API_KEY=
CREDENTIALS_PATH=credentials.json
SHEET_NAME=Keyword Tracker
GSC_SITE_URL=
GA4_PROPERTY_ID=

# === Optional — SERP Providers ===
SEARCHAPI_API_KEY=
APIFY_API_KEY=

# === Optional — Groq / LLM ===
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY=

# === Optional — Provider order override (comma-separated) ===
# Default: serpapi,apify,browseros,searchapi
# PROVIDER_ORDER=browseros

# === Optional — Client Research (prevents hallucination) ===
# Get a free API key at https://tavily.com
# Used to auto-discover client niche + business type before audits
TAVILY_API_KEY=tvly-your_key_here

# === Firecrawl (public website crawling for manual audits) ===
# Get a free API key at https://www.firecrawl.dev
FIRECRAWL_API_KEY=fc-your_key_here

# === Upstash Redis (serverless — https://upstash.com) ===
UPSTASH_REDIS_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_TOKEN=your_token_here

# === Grafana Cloud (OpenTelemetry — https://grafana.com) ===
OTEL_SERVICE_NAME=seo-autopilot
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-ap-south-1.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20your_base64_encoded_credentials
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# === Security ===
# API authentication key — all /api/ endpoints require X-API-Key header when set
# Leave empty to disable auth (single-user/local only)
API_AUTH_KEY=
# Comma-separated CORS allowlist
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# === Playwright Browser ===
# HTTP/SOCKS5 proxy for all browser sessions (e.g. http://user:pass@host:port)
# Leave empty to use direct connection
BROWSER_PROXY_URL=

# === Runtime ===
MAX_KEYWORDS=3
